{
  "bar": {
    "name_zh": "柱状图",
    "kind": "series",
    "imd_priority": "core",
    "min_fields": "2",
    "data_shape": "table_rows",
    "required": [
      {
        "id": "category",
        "label": "分类/X轴",
        "required": true,
        "types": [
          "text",
          "category",
          "date"
        ],
        "description": "每个柱子的类目、时间或分组"
      },
      {
        "id": "value",
        "label": "数值/Y轴",
        "required": true,
        "types": [
          "number"
        ],
        "description": "柱子高度或长度"
      }
    ],
    "optional": [
      {
        "id": "series",
        "label": "分组/系列",
        "required": false,
        "types": [
          "text",
          "category"
        ],
        "description": "生成多系列或堆叠柱状图"
      },
      {
        "id": "stack",
        "label": "堆叠组",
        "required": false,
        "types": [
          "text",
          "category"
        ],
        "description": "把多个系列堆叠显示"
      }
    ],
    "strategy": "优先选择低基数文本/日期字段做 category，选择第一个数值字段做 value。"
  },
  "line": {
    "name_zh": "折线图",
    "kind": "series",
    "imd_priority": "core",
    "min_fields": "2",
    "data_shape": "table_rows",
